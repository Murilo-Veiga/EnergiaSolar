{
  "info": {
    "name": "Solar Home — APIs do projeto",
    "description": "Coleção com as APIs realmente usadas no projeto EnergiaSolar: Huawei FusionSolar NBI, FoxESS Cloud OpenAPI, Open-Meteo e o webapp local (FastAPI). Gerada a partir do código em collector/huawei_client.py, collector/foxess_client.py e webapp/main.py — não da doc oficial (a doc da Huawei é uma SPA que não expõe conteúdo estático).\n\nUse o environment 'Solar Home' junto com esta collection e preencha as variáveis marcadas como secretas antes de rodar.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Huawei FusionSolar NBI",
      "description": "Northbound Interface oficial da Huawei. Rate limit confirmado por teste: 1 chamada a cada ~300s por interface (exceto login, sem limite, e getAlarmList, que na prática exige ~592-888s — ver README do projeto). Autenticação: login retorna cookie de sessão (guardado automaticamente pelo Postman) + xsrf-token no HEADER da resposta (não no corpo) — o script do request de Login já captura isso em {{huawei_xsrf_token}} para as chamadas seguintes.",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userName\": \"{{huawei_username}}\",\n  \"systemCode\": \"{{huawei_system_code}}\"\n}"
            },
            "url": {
              "raw": "{{huawei_base_url}}/thirdData/login",
              "host": ["{{huawei_base_url}}"],
              "path": ["thirdData", "login"]
            },
            "description": "Sem rate limit. Resposta: {success: bool}. O xsrf-token vem no HEADER da resposta, não no corpo — capturado pelo script de teste abaixo."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const xsrf = pm.response.headers.get('xsrf-token');",
                  "if (xsrf) {",
                  "    pm.environment.set('huawei_xsrf_token', xsrf);",
                  "    console.log('xsrf-token capturado:', xsrf);",
                  "} else {",
                  "    console.warn('xsrf-token nao veio no header da resposta');",
                  "}",
                  "pm.test('login success == true', function () {",
                  "    pm.expect(pm.response.json().success).to.eql(true);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "getStationList",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "XSRF-TOKEN", "value": "{{huawei_xsrf_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": {
              "raw": "{{huawei_base_url}}/thirdData/getStationList",
              "host": ["{{huawei_base_url}}"],
              "path": ["thirdData", "getStationList"]
            },
            "description": "Lista as usinas (stations) da conta. Retorna stationCode, usado nas demais chamadas."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.success && data.data && data.data.length) {",
                  "    pm.environment.set('huawei_station_code', data.data[0].stationCode);",
                  "    console.log('stationCode capturado:', data.data[0].stationCode);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "getDevList",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "XSRF-TOKEN", "value": "{{huawei_xsrf_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"stationCodes\": \"{{huawei_station_code}}\"\n}"
            },
            "url": {
              "raw": "{{huawei_base_url}}/thirdData/getDevList",
              "host": ["{{huawei_base_url}}"],
              "path": ["thirdData", "getDevList"]
            },
            "description": "Lista os dispositivos (inversores) da usina. Retorna devDn, usado em getDevRealKpi."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.success && data.data && data.data.length) {",
                  "    pm.environment.set('huawei_dev_dn', data.data[0].devDn);",
                  "    console.log('devDn capturado:', data.data[0].devDn);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "getStationRealKpi",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "XSRF-TOKEN", "value": "{{huawei_xsrf_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"stationCodes\": \"{{huawei_station_code}}\"\n}"
            },
            "url": {
              "raw": "{{huawei_base_url}}/thirdData/getStationRealKpi",
              "host": ["{{huawei_base_url}}"],
              "path": ["thirdData", "getStationRealKpi"]
            },
            "description": "KPI em tempo real da usina (dataItemMap.day_power usado como fallback de geração do dia no coletor). Rate limit: 1x/300s."
          }
        },
        {
          "name": "getDevRealKpi",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "XSRF-TOKEN", "value": "{{huawei_xsrf_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"devIds\": \"{{huawei_dev_dn}}\",\n  \"devTypeId\": 38\n}"
            },
            "url": {
              "raw": "{{huawei_base_url}}/thirdData/getDevRealKpi",
              "host": ["{{huawei_base_url}}"],
              "path": ["thirdData", "getDevRealKpi"]
            },
            "description": "KPI em tempo real do inversor. devTypeId=38 = inversor (fixo na taxonomia da NBI). Campos usados: dataItemMap.active_power (potência), day_cap (geração do dia), temperature. Rate limit: 1x/300s."
          }
        },
        {
          "name": "getAlarmList",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "XSRF-TOKEN", "value": "{{huawei_xsrf_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"stationCodes\": \"{{huawei_station_code}}\"\n}"
            },
            "url": {
              "raw": "{{huawei_base_url}}/thirdData/getAlarmList",
              "host": ["{{huawei_base_url}}"],
              "path": ["thirdData", "getAlarmList"]
            },
            "description": "Lista de alarmes ativos da usina. ATENCAO: rate limit próprio, medido empiricamente entre ~592s e ~888s — bem mais restrito que os outros endpoints (300s). Chamar com menos intervalo retorna failCode 407 ACCESS_FREQUENCY_IS_TOO_HIGH."
          }
        }
      ]
    },
    {
      "name": "FoxESS Cloud OpenAPI",
      "description": "Autenticação por token privado: headers token (API key), timestamp (ms) e signature = MD5(path + \"\\r\\n\" + token + \"\\r\\n\" + timestamp) — a FoxESS valida sobre a sequência literal de 4 caracteres \\r\\n, não bytes CR+LF reais (confirmado testando contra a API real). Rate limit: 1440 chamadas/dia por inversor, máx. 1/s. Cada request desta pasta tem um pre-request script que calcula timestamp/signature automaticamente.",
      "item": [
        {
          "name": "device/list",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const path = '/op/v0/device/list';",
                  "const token = pm.environment.get('foxess_api_key');",
                  "const timestamp = Date.now().toString();",
                  "const signature = CryptoJS.MD5(`${path}\\\\r\\\\n${token}\\\\r\\\\n${timestamp}`).toString();",
                  "pm.environment.set('foxess_timestamp', timestamp);",
                  "pm.environment.set('foxess_signature', signature);"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.errno === 0 && data.result && data.result.data && data.result.data.length) {",
                  "    pm.environment.set('foxess_device_sn', data.result.data[0].deviceSN);",
                  "    console.log('deviceSN capturado:', data.result.data[0].deviceSN);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "token", "value": "{{foxess_api_key}}" },
              { "key": "timestamp", "value": "{{foxess_timestamp}}" },
              { "key": "signature", "value": "{{foxess_signature}}" },
              { "key": "lang", "value": "en" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPage\": 1,\n  \"pageSize\": 10\n}"
            },
            "url": {
              "raw": "{{foxess_base_url}}/op/v0/device/list",
              "host": ["{{foxess_base_url}}"],
              "path": ["op", "v0", "device", "list"]
            },
            "description": "Descobre o deviceSN do inversor. Resposta em result.data[]."
          }
        },
        {
          "name": "device/real/query",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const path = '/op/v0/device/real/query';",
                  "const token = pm.environment.get('foxess_api_key');",
                  "const timestamp = Date.now().toString();",
                  "const signature = CryptoJS.MD5(`${path}\\\\r\\\\n${token}\\\\r\\\\n${timestamp}`).toString();",
                  "pm.environment.set('foxess_timestamp', timestamp);",
                  "pm.environment.set('foxess_signature', signature);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "token", "value": "{{foxess_api_key}}" },
              { "key": "timestamp", "value": "{{foxess_timestamp}}" },
              { "key": "signature", "value": "{{foxess_signature}}" },
              { "key": "lang", "value": "en" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sn\": \"{{foxess_device_sn}}\",\n  \"variables\": [\"generationPower\", \"todayYield\", \"invTemperation\"]\n}"
            },
            "url": {
              "raw": "{{foxess_base_url}}/op/v0/device/real/query",
              "host": ["{{foxess_base_url}}"],
              "path": ["op", "v0", "device", "real", "query"]
            },
            "description": "Potência/geração/temperatura instantâneas. Variáveis usadas pelo coletor: generationPower, todayYield, invTemperation."
          }
        },
        {
          "name": "device/history/query",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const path = '/op/v0/device/history/query';",
                  "const token = pm.environment.get('foxess_api_key');",
                  "const timestamp = Date.now().toString();",
                  "const signature = CryptoJS.MD5(`${path}\\\\r\\\\n${token}\\\\r\\\\n${timestamp}`).toString();",
                  "pm.environment.set('foxess_timestamp', timestamp);",
                  "pm.environment.set('foxess_signature', signature);",
                  "pm.environment.set('foxess_end_ms', Date.now().toString());",
                  "pm.environment.set('foxess_begin_ms', (Date.now() - 3 * 3600 * 1000).toString());"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "token", "value": "{{foxess_api_key}}" },
              { "key": "timestamp", "value": "{{foxess_timestamp}}" },
              { "key": "signature", "value": "{{foxess_signature}}" },
              { "key": "lang", "value": "en" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sn\": \"{{foxess_device_sn}}\",\n  \"variables\": [\"generationPower\"],\n  \"begin\": {{foxess_begin_ms}},\n  \"end\": {{foxess_end_ms}}\n}"
            },
            "url": {
              "raw": "{{foxess_base_url}}/op/v0/device/history/query",
              "host": ["{{foxess_base_url}}"],
              "path": ["op", "v0", "device", "history", "query"]
            },
            "description": "Curva histórica de até 24h, usada pelo coletor para a curva intradiária (janela de 3h a cada ciclo de 5min, com sobreposição — ver README)."
          }
        }
      ]
    },
    {
      "name": "Open-Meteo (previsão do tempo)",
      "description": "API pública, sem autenticação/API key. Chamada pelo webapp (_forecast_days em webapp/main.py), cacheada por 2h em memória.",
      "item": [
        {
          "name": "forecast",
          "request": {
            "method": "GET",
            "url": {
              "raw": "https://api.open-meteo.com/v1/forecast?latitude={{plant_lat}}&longitude={{plant_lon}}&daily=weathercode,temperature_2m_max,temperature_2m_min,shortwave_radiation_sum,precipitation_sum,precipitation_probability_max,sunrise,sunset&hourly=weathercode,cloudcover&timezone=America/Sao_Paulo&forecast_days=5",
              "protocol": "https",
              "host": ["api", "open-meteo", "com"],
              "path": ["v1", "forecast"],
              "query": [
                { "key": "latitude", "value": "{{plant_lat}}" },
                { "key": "longitude", "value": "{{plant_lon}}" },
                { "key": "daily", "value": "weathercode,temperature_2m_max,temperature_2m_min,shortwave_radiation_sum,precipitation_sum,precipitation_probability_max,sunrise,sunset" },
                { "key": "hourly", "value": "weathercode,cloudcover" },
                { "key": "timezone", "value": "America/Sao_Paulo" },
                { "key": "forecast_days", "value": "5" }
              ]
            },
            "description": "Parâmetros exatamente iguais aos usados por webapp/main.py::_forecast_days()."
          }
        }
      ]
    },
