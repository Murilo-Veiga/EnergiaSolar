    {
      "name": "FoxESS Cloud OpenAPI",
      "description": "Autenticação por token privado: headers token (API key), timestamp (ms) e signature = MD5(path + \"\\r\\n\" + token + \"\\r\\n\" + timestamp) — a FoxESS valida sobre a sequência literal de 4 caracteres \\r\\n, não bytes CR+LF reais (confirmado testando contra a API real). Rate limit: 1440 chamadas/dia por inversor, máx. 1/s. Cada request desta pasta tem um pre-request script que calcula timestamp/signature automaticamente.",
      "item": [
        {
          "name": "device/list",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const path = '/op/v0/device/list';",
                  "const token = pm.environment.get('foxess_api_key');",
                  "const timestamp = Date.now().toString();",
                  "const signature = CryptoJS.MD5(`${path}\\\\r\\\\n${token}\\\\r\\\\n${timestamp}`).toString();",
                  "pm.environment.set('foxess_timestamp', timestamp);",
                  "pm.environment.set('foxess_signature', signature);"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.errno === 0 && data.result && data.result.data && data.result.data.length) {",
                  "    pm.environment.set('foxess_device_sn', data.result.data[0].deviceSN);",
                  "    console.log('deviceSN capturado:', data.result.data[0].deviceSN);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "token",
                "value": "{{foxess_api_key}}"
              },
              {
                "key": "timestamp",
                "value": "{{foxess_timestamp}}"
              },
              {
                "key": "signature",
                "value": "{{foxess_signature}}"
              },
              {
                "key": "lang",
                "value": "en"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPage\": 1,\n  \"pageSize\": 10\n}"
            },
            "url": {
              "raw": "{{foxess_base_url}}/op/v0/device/list",
              "host": [
                "{{foxess_base_url}}"
              ],
              "path": [
                "op",
                "v0",
                "device",
                "list"
              ]
            },
            "description": "Descobre o deviceSN do inversor. Resposta em result.data[]."
          }
        },
        {
          "name": "device/real/query",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const path = '/op/v0/device/real/query';",
                  "const token = pm.environment.get('foxess_api_key');",
                  "const timestamp = Date.now().toString();",
                  "const signature = CryptoJS.MD5(`${path}\\\\r\\\\n${token}\\\\r\\\\n${timestamp}`).toString();",
                  "pm.environment.set('foxess_timestamp', timestamp);",
                  "pm.environment.set('foxess_signature', signature);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "token",
                "value": "{{foxess_api_key}}"
              },
              {
                "key": "timestamp",
                "value": "{{foxess_timestamp}}"
              },
              {
                "key": "signature",
                "value": "{{foxess_signature}}"
              },
              {
                "key": "lang",
                "value": "en"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sn\": \"{{foxess_device_sn}}\",\n  \"variables\": [\"generationPower\", \"todayYield\", \"invTemperation\"]\n}"
            },
            "url": {
              "raw": "{{foxess_base_url}}/op/v0/device/real/query",
              "host": [
                "{{foxess_base_url}}"
              ],
              "path": [
                "op",
                "v0",
                "device",
                "real",
                "query"
              ]
            },
            "description": "Potência/geração/temperatura instantâneas. Variáveis usadas pelo coletor: generationPower, todayYield, invTemperation."
          }
        },
        {
          "name": "device/history/query",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const path = '/op/v0/device/history/query';",
                  "const token = pm.environment.get('foxess_api_key');",
                  "const timestamp = Date.now().toString();",
                  "const signature = CryptoJS.MD5(`${path}\\\\r\\\\n${token}\\\\r\\\\n${timestamp}`).toString();",
                  "pm.environment.set('foxess_timestamp', timestamp);",
                  "pm.environment.set('foxess_signature', signature);",
                  "pm.environment.set('foxess_end_ms', Date.now().toString());",
                  "pm.environment.set('foxess_begin_ms', (Date.now() - 3 * 3600 * 1000).toString());"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "token",
                "value": "{{foxess_api_key}}"
              },
              {
                "key": "timestamp",
                "value": "{{foxess_timestamp}}"
              },
              {
                "key": "signature",
                "value": "{{foxess_signature}}"
              },
              {
                "key": "lang",
                "value": "en"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sn\": \"{{foxess_device_sn}}\",\n  \"variables\": [\"generationPower\"],\n  \"begin\": {{foxess_begin_ms}},\n  \"end\": {{foxess_end_ms}}\n}"
            },
            "url": {
              "raw": "{{foxess_base_url}}/op/v0/device/history/query",
              "host": [
                "{{foxess_base_url}}"
              ],
              "path": [
                "op",
                "v0",
                "device",
                "history",
                "query"
              ]
            },
            "description": "Curva histórica de até 24h, usada pelo coletor para a curva intradiária (janela de 3h a cada ciclo de 5min, com sobreposição — ver README)."
          }
        }
      ]
    },
    {
      "name": "Open-Meteo (previsão do tempo)",
      "description": "API pública, sem autenticação/API key. Chamada pelo webapp (_forecast_days em webapp/main.py), cacheada por 2h em memória.",
      "item": [
        {
          "name": "forecast",
          "request": {
            "method": "GET",
            "url": {
              "raw": "https://api.open-meteo.com/v1/forecast?latitude={{plant_lat}}&longitude={{plant_lon}}&daily=weathercode,temperature_2m_max,temperature_2m_min,shortwave_radiation_sum,precipitation_sum,precipitation_probability_max,sunrise,sunset&hourly=weathercode,cloudcover&timezone=America/Sao_Paulo&forecast_days=5",
              "protocol": "https",
              "host": [
                "api",
                "open-meteo",
                "com"
              ],
              "path": [
                "v1",
                "forecast"
              ],
              "query": [
                {
                  "key": "latitude",
                  "value": "{{plant_lat}}"
                },
                {
                  "key": "longitude",
                  "value": "{{plant_lon}}"
                },
                {
                  "key": "daily",
                  "value": "weathercode,temperature_2m_max,temperature_2m_min,shortwave_radiation_sum,precipitation_sum,precipitation_probability_max,sunrise,sunset"
                },
                {
                  "key": "hourly",
                  "value": "weathercode,cloudcover"
                },
                {
                  "key": "timezone",
                  "value": "America/Sao_Paulo"
                },
                {
                  "key": "forecast_days",
                  "value": "5"
                }
              ]
            },
            "description": "Parâmetros exatamente iguais aos usados por webapp/main.py::_forecast_days()."
          }
        }
      ]
    }
