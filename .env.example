# Copie este arquivo para .env e preencha com os valores reais.
# O .env nunca deve ser commitado (já está no .gitignore).
#
# URL das integrações Huawei/FoxESS e intervalo do worker de coleta ficam na
# tela Administração > Configuração do sistema (admin), não são env var.

# --- Postgres ---
POSTGRES_USER=solarhome
POSTGRES_PASSWORD=
POSTGRES_DB=solarhome

# Assina o cookie de sessão (JWT) do api-go — gere com:
# python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

# Cifra credenciais de inversor em repouso no Postgres (AES-256) — precisa
# ter EXATAMENTE 32 bytes. Gere com:
# python3 -c "import secrets; print(secrets.token_hex(16))"
CONFIG_ENCRYPTION_KEY=

# --- Frontend React (web) ---
# CORS da api está liberado pra qualquer origem — não precisa configurar nada aqui.
# URL da api-go embutida no bundle estático do React em tempo de build.
VITE_API_URL=http://localhost:8091
