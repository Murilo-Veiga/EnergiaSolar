# Copie este arquivo para .env e preencha com os valores reais.
# O .env nunca deve ser commitado (já está no .gitignore).

# --- Huawei FusionSolar (Northbound API) — inversor SIW300H-3K ---
HUAWEI_USERNAME=
HUAWEI_SYSTEM_CODE=
# Servidor regional do NBI da conta (confirmado via teste: la5 = América Latina).
HUAWEI_BASE_URL=https://la5.fusionsolar.huawei.com

# --- FoxESS Cloud OpenAPI — inversor SIW200G-5K ---
# Autenticação por token privado (API key). Não usa client-id/OAuth.
FOXESS_API_KEY=
FOXESS_BASE_URL=https://www.foxesscloud.com

# --- Dados fixos da instalação (não vêm de API) ---
# 20 módulos de 610 Wp = 12,2 kWp instalados (nameplate DC)
PLANT_INSTALLED_POWER_KWP=12.2
# Coordenadas da usina — usadas para consultar a previsão do tempo (Open-Meteo)
PLANT_LAT=
PLANT_LON=

# --- InfluxDB (banco de dados de séries temporais) ---
INFLUXDB_ADMIN_USER=admin
INFLUXDB_ADMIN_PASSWORD=troque-esta-senha
INFLUXDB_ORG=energia-solar
INFLUXDB_BUCKET=solar-home
# Token gerado automaticamente no primeiro start do container (ver README/setup)
INFLUXDB_TOKEN=

# Cadência mínima recomendada: 300s (a Huawei NBI restringe cada interface a
# no máximo 1 chamada a cada 5 minutos).
COLLECT_INTERVAL_SECONDS=300
