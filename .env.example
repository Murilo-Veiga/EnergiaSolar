# Copie este arquivo para .env e preencha com os valores reais.
# O .env nunca deve ser commitado (já está no .gitignore).

# --- Huawei FusionSolar (Northbound API) — inversor SIW300H-3K ---
# Desligar (false) remove o inversor inteiramente: o collector para de chamar
# a API da Huawei e o dashboard esconde o card/seções desse inversor — sem
# isso, desligar só no acesso à API geraria alerta falso de "sem comunicação".
HUAWEI_ENABLED=true
HUAWEI_USERNAME=
HUAWEI_SYSTEM_CODE=
# Servidor regional do NBI da conta (confirmado via teste: la5 = América Latina).
HUAWEI_BASE_URL=https://la5.fusionsolar.huawei.com

#Northbound API Reference: https://info.support.huawei.com/DpinfoAppBiz/#/u?i=TxvNXxKe&l=en_US

# --- FoxESS Cloud OpenAPI — inversor SIW200G-5K ---
# Mesma ideia do HUAWEI_ENABLED acima, para o inversor FoxESS.
FOXESS_ENABLED=false
# Autenticação por token privado (API key). Não usa client-id/OAuth.
FOXESS_API_KEY=
FOXESS_BASE_URL=https://www.foxesscloud.com

# --- Dados fixos da instalação (não vêm de API) ---
# Potência instalada (nameplate DC), em kWp — some da(s) placa(s) do(s) inversor(es).
PLANT_INSTALLED_POWER_KWP=
# Coordenadas da usina — usadas para consultar a previsão do tempo (Open-Meteo)
PLANT_LAT=
PLANT_LON=

# --- InfluxDB (banco de dados de séries temporais) ---
INFLUXDB_ADMIN_USER=admin
INFLUXDB_ADMIN_PASSWORD=troque-esta-senha
INFLUXDB_ORG=energia-solar
INFLUXDB_BUCKET=solar-home
# Token gerado automaticamente no primeiro start do container (ver README/setup)
INFLUXDB_TOKEN=

# Cadência mínima recomendada: 300s (a Huawei NBI restringe cada interface a
# no máximo 1 chamada a cada 5 minutos).
COLLECT_INTERVAL_SECONDS=300

# --- Stack novo (Go + Postgres + React) — ver plano em
# /home/marcos/.claude/plans/polymorphic-humming-fog.md. Roda ao lado do
# stack Python/InfluxDB acima até atingir paridade validada. ---
POSTGRES_USER=solarhome
POSTGRES_PASSWORD=
POSTGRES_DB=solarhome

# Assina o cookie de sessão (JWT) do api-go — gere com:
# python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

# Cifra credenciais de inversor em repouso no Postgres (AES-256) — precisa
# ter EXATAMENTE 32 bytes. Gere com:
# python3 -c "import secrets; print(secrets.token_hex(16))"
CONFIG_ENCRYPTION_KEY=

# Usados só pelo script de seed (cmd/seed), que migra o .env acima (Huawei +
# coordenadas + potência instalada) pro primeiro usuário/usina no Postgres.
SEED_USER_EMAIL=
SEED_USER_PASSWORD=
